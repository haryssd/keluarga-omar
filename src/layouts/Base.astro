---
export interface Props {
  title?: string;
  description?: string;
}
const { title = "Keluarga Omar", description = "Pokok Keluarga Omar — 4 Generasi" } = Astro.props;
---
<!DOCTYPE html>
<html lang="ms">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <!-- Preload font CSS so it doesn't block first paint -->
  <link rel="preload" as="style" href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Lato:wght@300;400;500&display=swap" />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,500;0,700;1,500&family=Lato:wght@300;400;500&display=swap" rel="stylesheet" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Lato', sans-serif;
      background: #fdf7ec;
      min-height: 100vh;
      overflow-x: hidden;
    }
  </style>
</head>
<body>

  <!-- ── SPLASH SCREEN ── -->
  <div id="splash">
    <div class="splash-inner">
      <div class="splash-diamonds" aria-hidden="true">
        <svg width="120" height="16" viewBox="0 0 120 16">
          <rect x="2"   y="5"  width="6"  height="6"  transform="rotate(45 5 8)"    fill="#e8c46a" opacity="0.3"/>
          <rect x="15"  y="4"  width="8"  height="8"  transform="rotate(45 19 8)"   fill="#e8c46a" opacity="0.55"/>
          <rect x="31"  y="2"  width="12" height="12" transform="rotate(45 37 8)"   fill="#e8c46a" opacity="0.8"/>
          <rect x="51"  y="1"  width="14" height="14" transform="rotate(45 58 8)"   fill="#e8c46a"/>
          <rect x="73"  y="2"  width="12" height="12" transform="rotate(45 79 8)"   fill="#e8c46a" opacity="0.8"/>
          <rect x="91"  y="4"  width="8"  height="8"  transform="rotate(45 95 8)"   fill="#e8c46a" opacity="0.55"/>
          <rect x="107" y="5"  width="6"  height="6"  transform="rotate(45 110 8)"  fill="#e8c46a" opacity="0.3"/>
        </svg>
      </div>
      <div class="splash-subtitle">بِسْمِ اللَّهِ الرَّحْمَنِ الرَّحِيم</div>
      <div class="splash-title">Keluarga Omar</div>
      <div class="splash-tagline">Pokok Keluarga · 4 Generasi</div>
      <div class="splash-diamonds" aria-hidden="true">
        <svg width="120" height="16" viewBox="0 0 120 16">
          <rect x="2"   y="5"  width="6"  height="6"  transform="rotate(45 5 8)"    fill="#e8c46a" opacity="0.3"/>
          <rect x="15"  y="4"  width="8"  height="8"  transform="rotate(45 19 8)"   fill="#e8c46a" opacity="0.55"/>
          <rect x="31"  y="2"  width="12" height="12" transform="rotate(45 37 8)"   fill="#e8c46a" opacity="0.8"/>
          <rect x="51"  y="1"  width="14" height="14" transform="rotate(45 58 8)"   fill="#e8c46a"/>
          <rect x="73"  y="2"  width="12" height="12" transform="rotate(45 79 8)"   fill="#e8c46a" opacity="0.8"/>
          <rect x="91"  y="4"  width="8"  height="8"  transform="rotate(45 95 8)"   fill="#e8c46a" opacity="0.55"/>
          <rect x="107" y="5"  width="6"  height="6"  transform="rotate(45 110 8)"  fill="#e8c46a" opacity="0.3"/>
        </svg>
      </div>
    </div>
  </div>

  <slot />

  <style>
    /* ── Splash screen ── */
    #splash {
      position: fixed;
      inset: 0;
      z-index: 9999;
      background: linear-gradient(160deg, #1e5235 0%, #173d28 60%, #0f2a1a 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      flex-direction: column;
      animation: splash-fade-out 1.8s cubic-bezier(0.4, 0, 0.2, 1) forwards;
      animation-delay: 9s;
      pointer-events: none;
    }
    @keyframes splash-fade-out {
      0%   { opacity: 1; transform: scale(1); }
      60%  { opacity: 0.4; transform: scale(1.015); }
      100% { opacity: 0; transform: scale(1.03); visibility: hidden; }
    }
    .splash-inner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 14px;
      animation: splash-content-in 0.7s cubic-bezier(0.16,1,0.3,1) both;
    }
    @keyframes splash-content-in {
      from { opacity: 0; transform: translateY(18px); }
      to   { opacity: 1; transform: translateY(0); }
    }
    .splash-subtitle {
      font-family: 'Playfair Display', serif;
      font-size: clamp(13px, 3vw, 16px);
      color: rgba(232, 196, 106, 0.7);
      letter-spacing: 0.06em;
      font-style: italic;
    }
    .splash-title {
      font-family: 'Playfair Display', serif;
      font-size: clamp(32px, 8vw, 56px);
      font-weight: 700;
      color: #e8c46a;
      letter-spacing: 0.04em;
      text-shadow: 0 2px 24px rgba(232,196,106,0.3);
      line-height: 1.1;
    }
    .splash-tagline {
      font-family: 'Lato', sans-serif;
      font-size: clamp(11px, 2.5vw, 14px);
      font-weight: 300;
      color: rgba(245, 228, 176, 0.75);
      letter-spacing: 0.22em;
      text-transform: uppercase;
    }
  </style>

  <script>
    // Remove from DOM after animation completes so it doesn't block interaction
    const splash = document.getElementById('splash');
    if (splash) {
      splash.addEventListener('animationend', () => splash.remove());
    }
  </script>

</body>
</html>
