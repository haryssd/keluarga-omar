    background: var(--cream);
    position: relative;
    overflow: hidden;
    font-family: 'Lato', sans-serif;
  }

  /* ── SONGKET BG ── */
  .songket-bg {
    position: absolute; inset: 0;
    pointer-events: none;
    opacity: 0.08;
    z-index: 0;
  }

  /* ── HEADER ── */
  .ft-head {
    background: var(--hijau);
    position: relative; z-index: 1;
    animation: ft-head-fade 0.6s ease both;
  }
  .head-top-stripe {
    height: 6px;
    background: linear-gradient(90deg, var(--hijau2), var(--emas), var(--emas2), var(--emas), var(--hijau2));
  }
  .ft-head-inner {
    position: relative; z-index: 2;
    text-align: center;
    padding: 30px 20px 24px;
  }
  .head-title-row {
    display: flex; justify-content: center;
    align-items: center; gap: 14px;
