  }
  .mob-gen-header:active { background: rgba(201,146,42,0.05); }

  /* Open state: deep green with gold accents */
  .mob-gen-section.open > .mob-gen-header {
    background: linear-gradient(135deg, #173d28 0%, #1e5235 100%);
  }
  .mob-gen-section.open > .mob-gen-header::before {
    background: linear-gradient(to bottom, var(--emas2), rgba(232,196,106,0.4));
  }

  /* Roman numeral badge */
  .mob-gen-numeral {
    width: 38px; height: 38px; flex-shrink: 0;
    border-radius: 50%;
    border: 2px solid var(--emas);
    background: linear-gradient(135deg, rgba(201,146,42,0.14), rgba(201,146,42,0.06));
    display: flex; align-items: center; justify-content: center;
    font-family: 'Playfair Display', serif;
    font-size: 13px; font-weight: 700;
    color: var(--emas);
    transition: all 0.25s;
  }
  .mob-gen-section.open > .mob-gen-header .mob-gen-numeral {
    background: rgba(232,196,106,0.18);
    color: var(--emas2); border-color: var(--emas2);
    box-shadow: 0 0 0 3px rgba(232,196,106,0.12);
  }

  /* Title + subtitle */
  .mob-gen-label { flex: 1; }
  .mob-gen-title {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 14px; font-weight: 700;
    color: #1a0e00;
    transition: color 0.25s;
  }
  .mob-gen-section.open > .mob-gen-header .mob-gen-title { color: var(--emas2); }
  .mob-gen-sub {
    display: block; margin-top: 2px;
    font-size: 9px; font-weight: 700;
    color: var(--emas); letter-spacing: 0.15em; text-transform: uppercase;
    transition: color 0.25s;
  }
  .mob-gen-section.open > .mob-gen-header .mob-gen-sub { color: rgba(232,196,106,0.65); }

  /* Member count pill */
  .mob-gen-count {
    font-size: 10px; font-weight: 600;
    color: var(--hijau);
    background: rgba(23,61,40,0.07);
    border: 1px solid rgba(23,61,40,0.14);
    border-radius: 20px; padding: 3px 10px;
    flex-shrink: 0;
    transition: all 0.25s;
  }
  .mob-gen-section.open > .mob-gen-header .mob-gen-count {
    background: rgba(232,196,106,0.15);
    color: var(--emas2); border-color: rgba(232,196,106,0.3);
  }

  /* Chevron arrow */
  .mob-gen-chevron {
    flex-shrink: 0; color: var(--text3);
    transition: transform 0.28s cubic-bezier(0.4,0,0.2,1), color 0.25s;
  }
  .mob-gen-section.open > .mob-gen-header .mob-gen-chevron {
    transform: rotate(180deg); color: var(--emas2);
  }

  /* Collapsible body */
  .mob-gen-body {
    max-height: 0; overflow: hidden;
    transition: max-height 0.38s cubic-bezier(0.4,0,0.2,1);
    background: #fafaf8;
  }
  .mob-gen-section.open > .mob-gen-body {
    max-height: 4800px;
    transition: max-height 0.5s cubic-bezier(0.4,0,0.2,1);
  }

  /* ── Parent sub-group (collapsible) ── */
  .mob-parent-group {
    padding: 10px 14px;
    border-top: 1px solid rgba(201,146,42,0.1);
  }
  .mob-parent-group:first-child { border-top: none; padding-top: 12px; }
  .mob-parent-group--flat { padding: 14px; }

  /* Sub-header button */
  .mob-parent-header {
    width: 100%; display: flex; align-items: center; gap: 8px;
    background: rgba(201,146,42,0.05);
    border: 1px solid rgba(201,146,42,0.15);
    border-radius: 8px; cursor: pointer;
    padding: 8px 12px; text-align: left;
    -webkit-tap-highlight-color: transparent;
    transition: background 0.15s, border-color 0.15s;
  }
  .mob-parent-header:active { background: rgba(201,146,42,0.12); }
  .mob-parent-group.open > .mob-parent-header {
    background: rgba(23,61,40,0.06);
    border-color: rgba(23,61,40,0.2);
  }

  .mob-parent-icon {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.34,1.56,0.64,1), opacity 0.2s;
    opacity: 0.85;
  }
  .mob-parent-group.open > .mob-parent-header .mob-parent-icon {
    transform: rotate(45deg);
    opacity: 1;
  }

  .mob-parent-name { flex: 1; font-size: 11px; color: var(--text2); }
  .mob-parent-name strong { color: var(--hijau); font-weight: 700; }
  .mob-parent-group.open > .mob-parent-header .mob-parent-name strong { color: var(--hijau2); }

  .mob-parent-count {
    font-size: 9px; font-weight: 600;
    color: var(--text3);
    background: rgba(201,146,42,0.08);
    border: 1px solid rgba(201,146,42,0.15);
    border-radius: 12px; padding: 1px 7px;
    flex-shrink: 0;
  }
  .mob-parent-chevron {
    flex-shrink: 0; color: var(--text3);
    transition: transform 0.25s cubic-bezier(0.4,0,0.2,1), color 0.2s;
  }
  .mob-parent-group.open > .mob-parent-header .mob-parent-chevron {
    transform: rotate(180deg); color: var(--emas);
  }

  /* Collapsible sub-body */
  .mob-parent-body {
    max-height: 0; overflow: hidden;
    transition: max-height 0.3s cubic-bezier(0.4,0,0.2,1);
  }
  .mob-parent-group.open > .mob-parent-body {
    max-height: 1200px;
  }
  .mob-parent-body .mob-gen-grid { padding-top: 10px; }

  /* Card grid */
  .mob-gen-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  /* Flat grid (Gen 1 / ungrouped) */
  .mob-parent-group--flat .mob-gen-grid { padding: 0; }

  /* ── Person card ── */
  .mob-card {
    background: #ffffff;
    border: 1px solid rgba(201,146,42,0.3);
    border-top: 2.5px solid var(--emas);
    border-radius: 12px;
