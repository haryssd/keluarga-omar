    font-family: 'Playfair Display', serif;
    font-size: clamp(34px, 6vw, 52px);
    font-weight: 700;
    color: var(--emas2);
    letter-spacing: 0.06em;
    line-height: 1.15;
    text-shadow: 0 2px 16px rgba(201,146,42,0.25);
  }
  .ft-head-sub {
    font-size: clamp(12px, 1.8vw, 15px);
    font-weight: 400;
    color: var(--emas3);
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin-bottom: 14px;
    opacity: 0.9;
  }
  .head-diamonds {
    display: flex; justify-content: center;
    align-items: center; gap: 10px;
  }
  .head-diamond-line {
    flex: 1; max-width: 90px; height: 1px;
    background: linear-gradient(90deg, transparent, var(--emas), transparent);
    opacity: 0.7;
  }
  .head-bottom-stripe {
    height: 5px;
    background: linear-gradient(90deg, var(--hijau2), var(--emas), var(--emas2), var(--emas), var(--hijau2));
  }

  /* ── TREE AREA ── */
  .ft-tree-wrap {
    overflow-x: auto;
    overflow-y: visible;
    padding: 36px 28px 24px;
    cursor: grab;
    position: relative; z-index: 1;
    -webkit-overflow-scrolling: touch;
  }
  .ft-tree-wrap:active { cursor: grabbing; }
  .ft-tree {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-width: 860px;
    width: max-content;
    margin: 0 auto;
    zoom: 1.15;
    animation: ft-fade-up 0.7s 0.15s cubic-bezier(0.22, 1, 0.36, 1) both;
  }

  /* ── FAMILY GROUP ── */
  .ft-gen-group {
    display: flex; flex-direction: column; align-items: center;
  }

  /* Fixed-height slot that lives in ft-child-col, above ft-gen-group.
     The note-slot is position:absolute so it is OUT OF FLOW and cannot
     affect the couple's vertical position.  The couple's position is
     determined solely by the column's padding-top, which is the same
     for every sibling in the group. */

  /* All columns in a noted group get extra padding so the couple starts
     at the same Y as in noted siblings. */
  .ft-children--with-notes > .ft-child-col {
    padding-top: calc(22px + 26px); /* 48px total */
  }
  /* Vertical connector extended to match the new padding */
  .ft-children--with-notes > .ft-child-col::after {
    height: calc(22px + 26px);
  }
  /* Note slot is absolutely positioned inside the padding area —
     it does NOT participate in flex flow so it cannot shift the couple. */
  .ft-note-slot {
    position: absolute;
    top: 22px;          /* sit just below the connector's original end */
    left: 0; right: 0;
    height: 26px;
    display: flex; align-items: center; justify-content: center;
  }
  .ft-marriage-note-inner {
    font-size: 9px; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.14em;
    color: #173d28;
    background: linear-gradient(135deg, rgba(201,146,42,0.18), rgba(201,146,42,0.08));
    border: 1px solid rgba(201,146,42,0.45);
