  .ft-diamond {
    width: 10px; height: 10px;
    background: var(--emas);
    transform: rotate(45deg);
    flex-shrink: 0;
    border: 1.5px solid var(--emas2);
    animation: ft-diamond-pulse 3s ease-in-out infinite;
    will-change: box-shadow;
  }
  .ft-connector {
    display: flex; flex-direction: column; align-items: center;
  }
  .v-line {
    width: 2px;
    background: linear-gradient(to bottom, var(--emas), rgba(201,146,42,0.4));
  }
  .v-short { height: 22px; }
  .ft-children {
    display: flex; justify-content: center; align-items: flex-start;
  }

  /*
   * CSS-native H-branch + V-drop.
   * Each ft-child-col draws its own horizontal segment (::before) and
   * vertical drop (::after) using absolute positioning. Adjacent ::before
   * segments touch edge-to-edge, forming a seamless horizontal branch line
   * regardless of how wide each child subtree is — no JS measurement needed.
   *
   *  :first-child::before  starts at 50% (center of first child)
   *  middle children       span full width including margins
   *  :last-child::before   ends  at 50% (center of last child)
   *  single child          left:50% + right:50% = zero width → invisible
   */
  .ft-child-col {
    display: flex; flex-direction: column; align-items: center;
    margin: 0 6px;
    padding-top: 22px;
    position: relative;
  }
  /* Horizontal branch segment */
  .ft-child-col::before {
    content: '';
    position: absolute;
    top: 0; left: -6px; right: -6px;
    height: 2px;
    background: var(--emas);
  }
  .ft-child-col:first-child::before { left: 50%; }
  .ft-child-col:last-child::before  { right: 50%; }
  /* Vertical drop from H-branch down to the child's couple */
  .ft-child-col::after {
    content: '';
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 2px; height: 22px;
    background: linear-gradient(to bottom, var(--emas), rgba(201,146,42,0.5));
  }

  /* ── PERSON ── */
  .ft-person {
    display: flex; flex-direction: column; align-items: center;
    cursor: pointer;
    padding: 6px 4px;
    border-radius: 10px;
    transition:
      transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
      background 0.18s,
      filter 0.22s;
    outline: none;
    will-change: transform;
  }
  .ft-person:hover, .ft-person:focus-visible {
    transform: translateY(-6px) scale(1.07);
    background: rgba(201, 146, 42, 0.08);
    filter: drop-shadow(0 8px 16px rgba(201,146,42,0.35));
  }
  .ft-person:focus-visible { box-shadow: 0 0 0 2px var(--emas); }

  /*
   * Avatar layout — both rings share the same 76×76 parent so they are
   * always mathematically concentric, regardless of block-flow rounding.
   *
   *  ft-avatar-wrap  76×76  (position: relative — coordinate origin)
   *  ft-avatar-frame  inset:0  → 76×76  (the outer ring)
   *  ft-avatar        inset:4px → 68×68  (the filled circle, centred)
   */
  .ft-avatar-wrap {
    position: relative;
    width: 76px; height: 76px;
    flex-shrink: 0;
  }
  .ft-avatar-frame {
    position: absolute; inset: 0;
    border-radius: 50%;
    border: 2px solid var(--emas);
    z-index: 1;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .ft-person:hover .ft-avatar-frame,
  .ft-person:focus-visible .ft-avatar-frame {
    border-color: var(--emas2);
    box-shadow: 0 0 0 3px rgba(232,196,106,0.2);
  }
  /* Diamond side accents removed — clean circle only */
  .ft-avatar-frame::before,
  .ft-avatar-frame::after { content: none; }

  .ft-avatar-wrap.deceased .ft-avatar-frame {
    border-style: dashed;
    border-color: var(--text3);
  }
  .ft-avatar-wrap.deceased .ft-avatar-frame::before,
  .ft-avatar-wrap.deceased .ft-avatar-frame::after {
    background: var(--text3);
  }

  .ft-avatar {
    position: absolute; inset: 4px; /* 68×68, perfectly centred in the 76×76 wrap */
    border-radius: 50%;
    background: var(--emas3);
    display: flex; align-items: center; justify-content: center;
    overflow: hidden;
    z-index: 2;
    border: 2px solid var(--cream);
    box-shadow: inset 0 0 0 2px rgba(201,146,42,0.15);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .ft-person:hover .ft-avatar,
  .ft-person:focus-visible .ft-avatar {
    border-color: var(--emas2);
    box-shadow: inset 0 0 0 2px rgba(232,196,106,0.4);
  }

  .ft-avatar img { width: 100%; height: 100%; object-fit: cover; }
  .ft-initials {
