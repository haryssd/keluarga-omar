---
import type { FamilyData, TreeNode } from '../types/family';

export interface Props {
  data: FamilyData;
}

const { data } = Astro.props;
const { people, tree, familyName, subtitle } = data;

const GEN_LABELS: Record<number, string> = {
  1: 'Generasi 1 — Datuk & Nenek',
  2: 'Generasi 2 — Anak-anak',
  3: 'Generasi 3 — Cucu-cucu',
  4: 'Generasi 4 — Cicit-cicit',
};

function renderPerson(id: string, isPatriarch: boolean): string {
  const p = people[id];
  if (!p) return '';
  const firstName = p.name.split(' ')[0];
  const wrapCls = p.deceased ? 'ft-avatar-wrap deceased' : 'ft-avatar-wrap';
  const avCls   = [
    'ft-avatar',
    isPatriarch ? 'patriarch' : '',
    p.deceased  ? 'deceased'  : '',
  ].filter(Boolean).join(' ');
  const nameCls = isPatriarch ? 'ft-name patriarch-name' : 'ft-name';
  const photoEl = p.photo
    ? `<img src="${p.photo}" alt="${p.name}" loading="lazy" />`
    : `<span class="ft-initials">${p.initials}</span>`;
  return `
    <div class="ft-person" data-id="${id}" role="button" tabindex="0" aria-label="${p.name}">
      <div class="${wrapCls}">
        <div class="ft-avatar-frame" aria-hidden="true"></div>
        <div class="${avCls}">${photoEl}</div>
      </div>
      <div class="${nameCls}">${p.name}</div>
    </div>`;
}

function renderCouple(ids: string[], isPatriarch: boolean): string {
  if (ids.length === 1) return renderPerson(ids[0], false);
  return `
    <div class="ft-couple">
      ${renderPerson(ids[0], isPatriarch)}
      <div class="ft-conn" aria-hidden="true">
        <div class="ft-conn-line"></div>
        <div class="ft-diamond"></div>
        <div class="ft-conn-line"></div>
      </div>
      ${renderPerson(ids[1], isPatriarch)}
    </div>`;
}

function renderFamily(node: TreeNode, isRoot: boolean): string {
  const childCount = node.children.length;
  // If ANY child has a marriage note, give ALL siblings a fixed-height
  // note slot so their couple cards start at the exact same vertical position.
  const anyChildHasNote = node.children.some(c => c.note);

  const childrenHtml = node.children
    .map(child => {
      const noteSlot = anyChildHasNote
        ? `<div class="ft-note-slot">${child.note
            ? `<span class="ft-marriage-note-inner">${child.note}</span>`
            : ''}</div>`
        : '';
      return `
        <div class="ft-child-col">
          ${noteSlot}
          ${renderFamily(child, false)}
        </div>`;
    })
    .join('');

  return `
    <div class="ft-gen-group">
      ${renderCouple(node.couple, isRoot)}
      ${childCount > 0 ? `
        <div class="ft-connector" aria-hidden="true">
          <div class="v-line v-short"></div>
        </div>
        <div class="ft-children${anyChildHasNote ? ' ft-children--with-notes' : ''}">${childrenHtml}</div>
      ` : ''}
    </div>`;
}

const treeHtml = renderFamily(tree as TreeNode, true);
const peopleJson = JSON.stringify(people);
const genLabelsJson = JSON.stringify(GEN_LABELS);
const treeJson = JSON.stringify(tree);
---

<div id="ft">
  <!-- Songket background tile -->
  <div class="songket-bg" aria-hidden="true">
    <svg width="100%" height="100%" xmlns="http://www.w3.org/2000/svg">
      <defs>
        <pattern id="songket-pat" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
          <rect width="40" height="40" fill="none"/>
          <rect x="19" y="0"  width="2" height="2" fill="#1a5c3a"/>
          <rect x="19" y="19" width="2" height="2" fill="#1a5c3a"/>
          <rect x="0"  y="19" width="2" height="2" fill="#1a5c3a"/>
          <rect x="38" y="19" width="2" height="2" fill="#1a5c3a"/>
          <path d="M20 2 L22 10 L20 18 L18 10 Z" fill="#c9922a"/>
          <path d="M20 22 L22 30 L20 38 L18 30 Z" fill="#c9922a"/>
          <path d="M2 20 L10 22 L18 20 L10 18 Z"  fill="#c9922a"/>
          <path d="M22 20 L30 22 L38 20 L30 18 Z" fill="#c9922a"/>
          <rect x="18" y="8"  width="4" height="4" transform="rotate(45 20 10)" fill="#c9922a"/>
          <rect x="18" y="28" width="4" height="4" transform="rotate(45 20 30)" fill="#c9922a"/>
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#songket-pat)"/>
    </svg>
  </div>

  <!-- Header -->
  <header class="ft-head">
    <div class="head-top-stripe" aria-hidden="true"></div>
    <div class="ft-head-inner">
      <div class="head-title-row" aria-hidden="true">
        <svg width="32" height="32" viewBox="0 0 20 20"><rect x="8.5" y="0" width="3" height="20" fill="#c9922a" opacity="0.55"/><rect x="0" y="8.5" width="20" height="3" fill="#c9922a" opacity="0.55"/><rect x="7" y="7" width="6" height="6" transform="rotate(45 10 10)" fill="#e8c46a"/></svg>
        <h1 class="ft-head-title">{familyName}</h1>
        <svg width="32" height="32" viewBox="0 0 20 20"><rect x="8.5" y="0" width="3" height="20" fill="#c9922a" opacity="0.55"/><rect x="0" y="8.5" width="20" height="3" fill="#c9922a" opacity="0.55"/><rect x="7" y="7" width="6" height="6" transform="rotate(45 10 10)" fill="#e8c46a"/></svg>
      </div>
      <p class="ft-head-sub">{subtitle}</p>
      <div class="head-diamonds" aria-hidden="true">
        <div class="head-diamond-line"></div>
        <svg width="140" height="20" viewBox="0 0 100 16">
          <rect x="2"  y="6" width="5"  height="5"  transform="rotate(45 4.5 8.5)"  fill="#e8c46a" opacity="0.4"/>
          <rect x="14" y="5" width="7"  height="7"  transform="rotate(45 17.5 8.5)" fill="#e8c46a" opacity="0.65"/>
          <rect x="29" y="3" width="11" height="11" transform="rotate(45 34.5 8.5)" fill="#e8c46a"/>
          <rect x="44" y="3" width="11" height="11" transform="rotate(45 49.5 8.5)" fill="#e8c46a"/>
          <rect x="59" y="3" width="11" height="11" transform="rotate(45 64.5 8.5)" fill="#e8c46a"/>
          <rect x="75" y="5" width="7"  height="7"  transform="rotate(45 78.5 8.5)" fill="#e8c46a" opacity="0.65"/>
          <rect x="88" y="6" width="5"  height="5"  transform="rotate(45 90.5 8.5)" fill="#e8c46a" opacity="0.4"/>
        </svg>
        <div class="head-diamond-line"></div>
      </div>
    </div>
    <div class="head-bottom-stripe" aria-hidden="true"></div>
  </header>

  <!-- Tree scroll area -->
  <div class="ft-tree-wrap" id="treeWrap">
    <div class="ft-tree" id="ftTree" set:html={treeHtml}></div>
  </div>

  <!-- Legend -->
  <footer class="ft-legend">
    <div class="legend-item">
      <div class="legend-circle patriarch-circle"></div>
      <span>Patriarch / Matriarch</span>
    </div>
    <div class="legend-item">
      <div class="legend-circle"></div>
      <span>Ahli keluarga</span>
    </div>
    <div class="legend-item">
      <div class="legend-circle deceased-circle"></div>
      <span>Al-Fatihah (wafat)</span>
    </div>
    <div class="legend-item hint">
      <span>Klik untuk butiran &nbsp;·&nbsp; Scroll untuk lebih</span>
    </div>
  </footer>

  <!-- Mobile: Vertical Scroll / Family Album -->
  <div class="ft-mobile" id="ftMobile" aria-label="Paparan mudah alih">
    <div class="ft-mobile-content" id="ftMobContent"></div>
  </div>
</div>

<script define:vars={{ peopleJson, genLabelsJson, treeJson }}>
  const PEOPLE = JSON.parse(peopleJson);
  const GEN_LABELS = JSON.parse(genLabelsJson);
  const TREE = JSON.parse(treeJson);

  // ── Build parentMap: personId → [parentId, ...] (their parent couple) ──
  function buildParentMap(node, parentCouple) {
    const map = {};
    node.couple.forEach(function (id) {
      if (parentCouple) map[id] = parentCouple;
    });
    node.children.forEach(function (child) {
      Object.assign(map, buildParentMap(child, node.couple));
    });
    return map;
  }
  const parentMap = buildParentMap(TREE, null);

  // Returns array of parent couples from oldest ancestor to immediate parent
  function getAncestry(id) {
    const chain = [];
    let current = id;
    const visited = new Set();
    while (current) {
      if (visited.has(current)) break;
      visited.add(current);
      const parents = parentMap[current];
      if (!parents) break;
      chain.unshift(parents);
      current = parents[0];
    }
    return chain;
  }

  function openModal(id) {
    const p = PEOPLE[id];
    if (!p) return;

    const spouseId = p.spouse;
    const spouse = spouseId ? PEOPLE[spouseId] : null;

    const mAv = document.getElementById('mAvatar');
    const mInit = document.getElementById('mInitials');
    mInit.textContent = p.initials;
    mAv.className = 'modal-avatar';
    if (p.generation === 1) mAv.classList.add('patriarch');
    if (p.deceased) mAv.classList.add('deceased');

    if (p.photo) {
      mInit.style.display = 'none';
      let img = mAv.querySelector('img');
      if (!img) { img = document.createElement('img'); mAv.appendChild(img); }
      img.src = p.photo;
      img.alt = p.name;
    } else {
      mInit.style.display = '';
      const img = mAv.querySelector('img');
      if (img) img.remove();
    }

    document.getElementById('mName').textContent = p.name;
    const mNick = document.getElementById('mNickname');
    if (p.nickname) {
      mNick.textContent = p.nickname;
      mNick.style.display = 'inline-flex';
    } else {
      mNick.style.display = 'none';
    }
    document.getElementById('mRole').textContent = p.role;
    document.getElementById('mAlfatihah').style.display = p.deceased ? 'block' : 'none';

    // Generation ordinal in Malay
    const genOrdinal = ['', 'Pertama', 'Ke-2', 'Ke-3', 'Ke-4'][p.generation] ?? ('Ke-' + p.generation);

    // ── Lineage ancestry timeline ─────────────────────────────────────────
    const ancestry = getAncestry(id);
    let lineageHtml = '';
    if (ancestry.length > 0) {
      const ancestorRows = ancestry.map(function (couple) {
        const names = couple.map(function (pid) {
          return PEOPLE[pid] ? PEOPLE[pid].name : pid;
        }).join(' & ');
        const gen = PEOPLE[couple[0]] ? PEOPLE[couple[0]].generation : '';
        const genLabel = { 1: 'Generasi Pertama', 2: 'Generasi Ke-2', 3: 'Generasi Ke-3', 4: 'Generasi Ke-4' }[gen] || '';
        return `
          <div class="ml-row">
            <div class="ml-spine">
              <div class="ml-dot"></div>
              <div class="ml-line"></div>
            </div>
            <div class="ml-info">
              <button class="ml-name" data-open-id="${couple[0]}">${names}</button>
              ${genLabel ? `<span class="ml-gen">${genLabel}</span>` : ''}
            </div>
          </div>`;
      }).join('');

      lineageHtml = `
        <div class="modal-lineage">
          <div class="ml-title">
            <svg width="8" height="8" viewBox="0 0 8 8" aria-hidden="true"><rect x="1" y="1" width="6" height="6" transform="rotate(45 4 4)" fill="#c9922a"/></svg>
            Susur Galur
          </div>
          ${ancestorRows}
          <div class="ml-row ml-row-current">
            <div class="ml-spine">
              <div class="ml-dot ml-dot-current"></div>
            </div>
            <div class="ml-info">
              <span class="ml-name-current">${p.name}</span>
              <span class="ml-gen ml-gen-current">Generasi ${genOrdinal}</span>
            </div>
          </div>
        </div>`;
    }

    let body = lineageHtml;

    // ── Section 2: Pasangan (only if married) ────────────────────────────
    if (spouse) {
      body += `
      <div class="modal-section">
        <div class="modal-section-title">Pasangan</div>
        <div class="modal-spouse-card">
          <div class="modal-spouse-avatar">${spouse.initials}</div>
          <span class="modal-spouse-name">${spouse.name}</span>
        </div>
      </div>`;
    }

    // ── Alert: no photo ───────────────────────────────────────────────────
    if (!p.photo) {
      body += `
      <div class="modal-photo-alert">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="13" r="3"/>
          <path d="M20 8h-3.4L15 6H9L7.4 8H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V10a2 2 0 0 0-2-2z"/>
        </svg>
        <span>Belum ada gambar</span>
      </div>`;
    }

    document.getElementById('mBody').innerHTML = body;

    // Wire up lineage ancestor taps → open that person's modal
    document.querySelectorAll('.ml-name').forEach(function (el) {
      el.addEventListener('click', function () { openModal(el.dataset.openId); });
    });

    const overlay = document.getElementById('ft-overlay');
    overlay.classList.add('show');
    overlay.setAttribute('aria-hidden', 'false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    const overlay = document.getElementById('ft-overlay');
    overlay.classList.remove('show');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  // Expose globally so any inline handler can call it
  window.closeModal = closeModal;

  // All DOM queries are deferred until the full document is parsed,
  // because this define:vars script is an inline IIFE that runs before
  // Modal.astro's HTML (#modalClose, #ft-overlay) exists in the DOM.
  document.addEventListener('DOMContentLoaded', function () {
    // Close button inside Modal.astro
    document.getElementById('modalClose').addEventListener('click', closeModal);

    // Click outside modal card to close
    document.getElementById('ft-overlay').addEventListener('click', function (e) {
      if (e.target === e.currentTarget) closeModal();
    });

    // Escape key to close
    document.addEventListener('keydown', function (e) {
      if (e.key === 'Escape') closeModal();
    });

    // Attach open handlers to every person node in the tree
    document.querySelectorAll('.ft-person').forEach(function (el) {
      const id = el.dataset.id;
      el.addEventListener('click', function () { openModal(id); });
      el.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(id); }
      });
    });

    // ── Mobile: Vertical Scroll / Family Album ──────────────────────────
    const byGen = {};
    Object.keys(PEOPLE).forEach(function (id) {
      const gen = PEOPLE[id].generation;
      if (!byGen[gen]) byGen[gen] = [];
      byGen[gen].push(id);
    });

    const MOB_GEN_TITLES = {
      1: 'Generasi Pertama',
      2: 'Generasi Kedua',
      3: 'Generasi Ketiga',
      4: 'Generasi Keempat',
    };
    const MOB_GEN_SUBS = {
      1: 'Datuk & Nenek',
      2: 'Anak-anak',
      3: 'Cucu-cucu',
      4: 'Cicit-cicit',
    };

    function renderMobCard(id) {
      const p = PEOPLE[id];
      const avCls = ['mob-avatar', p.generation === 1 ? 'patriarch' : '', p.deceased ? 'deceased' : ''].filter(Boolean).join(' ');
      const photoEl = p.photo
        ? `<img src="${p.photo}" alt="${p.name}" loading="lazy" />`
        : `<span class="mob-initials">${p.initials}</span>`;
      return `
        <div class="mob-card" data-id="${id}" role="button" tabindex="0" aria-label="${p.name}">
          <div class="mob-avatar-wrap${p.deceased ? ' deceased' : ''}">
            <div class="mob-avatar-frame" aria-hidden="true"></div>
            <div class="${avCls}">${photoEl}</div>
          </div>
          <div class="mob-name">${p.name}</div>
          ${p.nickname ? `<div class="mob-nickname">${p.nickname}</div>` : ''}
          ${p.role !== p.nickname ? `<div class="mob-role">${p.role}</div>` : ''}
          ${p.deceased ? '<div class="mob-deceased">Al-Fatihah</div>' : ''}
        </div>`;
    }

    function renderMobCoupleCard(id1, id2) {
      function personInner(id) {
        const p = PEOPLE[id];
        const avCls = ['mob-avatar', p.generation === 1 ? 'patriarch' : '', p.deceased ? 'deceased' : ''].filter(Boolean).join(' ');
        const photoEl = p.photo
          ? `<img src="${p.photo}" alt="${p.name}" loading="lazy" />`
          : `<span class="mob-initials">${p.initials}</span>`;
        return `
          <div class="mob-card mob-card--coupled" data-id="${id}" role="button" tabindex="0" aria-label="${p.name}">
            <div class="mob-avatar-wrap${p.deceased ? ' deceased' : ''}">
              <div class="mob-avatar-frame" aria-hidden="true"></div>
              <div class="${avCls}">${photoEl}</div>
            </div>
            <div class="mob-name">${p.name}</div>
            ${p.nickname ? `<div class="mob-nickname">${p.nickname}</div>` : ''}
            ${p.role !== p.nickname ? `<div class="mob-role">${p.role}</div>` : ''}
            ${p.deceased ? '<div class="mob-deceased">Al-Fatihah</div>' : ''}
          </div>`;
      }
      return `
        <div class="mob-couple-row">
          ${personInner(id1)}
          <div class="mob-couple-conn" aria-hidden="true">
            <div class="mob-couple-line"></div>
            <div class="mob-couple-diamond"></div>
            <div class="mob-couple-line"></div>
          </div>
          ${personInner(id2)}
        </div>`;
    }

    function renderMobAll() {
      const content = document.getElementById('ftMobContent');
      if (!content) return;
      const gens = [1, 2, 3, 4].filter(function (g) { return byGen[g] && byGen[g].length; });

      content.innerHTML = gens.map(function (gen, idx) {
        const genNum = ['', 'I', 'II', 'III', 'IV'][gen] || gen;
        const isOpen = idx === 0;

        // ── Group people by their parent couple ──────────────────────────
        let bodyHtml;
        if (gen === 1) {
          // Root generation — no parent grouping
          bodyHtml = `<div class="mob-gen-grid">${byGen[gen].map(renderMobCard).join('')}</div>`;
        } else {
          const groups = [];
          const groupMap = {};
          byGen[gen].forEach(function (id) {
            const parents = parentMap[id];
            const key = parents ? parents.join('|') : '__none__';
            if (!groupMap[key]) {
              const g = { parents: parents || null, children: [] };
              groups.push(g);
              groupMap[key] = g;
            }
            groupMap[key].children.push(id);
          });

          if (gen === 2) {
            // ── Gen 2: static sub-headers + couple cards (no collapsible) ──
            const gen2Set = new Set(byGen[2]);
            const processed = new Set();

            // How many distinct parent groups exist (excluding __none__)?
            const namedGroupCount = groups.filter(function (g) { return g.parents; }).length;

            bodyHtml = groups.map(function (group) {
              // Only show sub-header when there are 2+ different parent groups
              // (e.g. Gen 2 all share same Gen 1 parents → no sub-header needed)
              let subHeaderHtml = '';
              if (group.parents && namedGroupCount > 1) {
                const parentNames = group.parents.map(function (pid) {
                  return PEOPLE[pid] ? PEOPLE[pid].name : pid;
                }).join(' & ');
                subHeaderHtml = `
                  <div class="mob-parent-header mob-parent-header--static">
                    <svg class="mob-parent-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
                      <ellipse cx="7" cy="3.2" rx="1.4" ry="2.8" fill="#c9922a"/>
                      <ellipse cx="7" cy="10.8" rx="1.4" ry="2.8" fill="#c9922a"/>
                      <ellipse cx="3.2" cy="7" rx="2.8" ry="1.4" fill="#c9922a"/>
                      <ellipse cx="10.8" cy="7" rx="2.8" ry="1.4" fill="#c9922a"/>
                      <circle cx="7" cy="7" r="1.8" fill="#173d28"/>
                    </svg>
                    <span class="mob-parent-name">Anak-anak <strong>${parentNames}</strong></span>
                    <span class="mob-parent-count">${group.children.length} orang</span>
                  </div>`;
              }

              const cards = [];
              group.children.forEach(function (id) {
                if (processed.has(id)) return;
                const p = PEOPLE[id];
                const spId = p.spouse;
                if (spId && gen2Set.has(spId) && !processed.has(spId)) {
                  cards.push(renderMobCoupleCard(id, spId));
                  processed.add(id);
                  processed.add(spId);
                } else {
                  cards.push(renderMobCard(id));
                  processed.add(id);
                }
              });

              if (cards.length === 0) return '';
              const cls = group.parents ? 'mob-parent-group' : 'mob-parent-group mob-parent-group--flat';
              return `<div class="${cls}">${subHeaderHtml}<div class="mob-gen-grid">${cards.join('')}</div></div>`;
            }).filter(Boolean).join('');

          } else {
            // ── Gen 3 / 4: collapsible sub-headers + couple cards ──
            const genSet = new Set(byGen[gen]);
            const processed = new Set();

            // Render children of a group with couple-card detection
            function renderGroupCards(children) {
              const cards = [];
              children.forEach(function (id) {
                if (processed.has(id)) return;
                const p = PEOPLE[id];
                const spId = p.spouse;
                if (spId && genSet.has(spId) && !processed.has(spId)) {
                  cards.push(renderMobCoupleCard(id, spId));
                  processed.add(id);
                  processed.add(spId);
                } else {
                  cards.push(renderMobCard(id));
                  processed.add(id);
                }
              });
              return cards.join('');
            }

            bodyHtml = groups.map(function (group) {
              if (!group.parents) {
                return `<div class="mob-parent-group mob-parent-group--flat"><div class="mob-gen-grid">${renderGroupCards(group.children)}</div></div>`;
              }
              const parentNames = group.parents.map(function (pid) {
                return PEOPLE[pid] ? PEOPLE[pid].name : pid;
              }).join(' & ');
              return `
                <div class="mob-parent-group">
                  <button class="mob-parent-header" aria-expanded="false">
                    <svg class="mob-parent-icon" width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
                      <ellipse cx="7" cy="3.2" rx="1.4" ry="2.8" fill="#c9922a"/>
                      <ellipse cx="7" cy="10.8" rx="1.4" ry="2.8" fill="#c9922a"/>
                      <ellipse cx="3.2" cy="7" rx="2.8" ry="1.4" fill="#c9922a"/>
                      <ellipse cx="10.8" cy="7" rx="2.8" ry="1.4" fill="#c9922a"/>
                      <circle cx="7" cy="7" r="1.8" fill="#173d28"/>
                    </svg>
                    <span class="mob-parent-name">Anak-anak <strong>${parentNames}</strong></span>
                    <span class="mob-parent-count">${group.children.length} orang</span>
                    <svg class="mob-parent-chevron" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="6 9 12 15 18 9"/></svg>
                  </button>
                  <div class="mob-parent-body">
                    <div class="mob-gen-grid">${renderGroupCards(group.children)}</div>
                  </div>
                </div>`;
            }).join('');
          }
        }

        return `
          <div class="mob-gen-section${isOpen ? ' open' : ''}">
            <button class="mob-gen-header" aria-expanded="${isOpen}" aria-controls="mob-body-${gen}">
              <div class="mob-gen-numeral">${genNum}</div>
              <div class="mob-gen-label">
                <span class="mob-gen-title">${MOB_GEN_TITLES[gen] || 'Generasi ' + gen}</span>
                <span class="mob-gen-sub">${MOB_GEN_SUBS[gen] || ''}</span>
              </div>
              <div class="mob-gen-count">${byGen[gen].length} orang</div>
              <svg class="mob-gen-chevron" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </button>
            <div class="mob-gen-body" id="mob-body-${gen}">
              ${bodyHtml}
            </div>
          </div>`;
      }).join('');

      // Accordion toggle
      content.querySelectorAll('.mob-gen-header').forEach(function (header) {
        header.addEventListener('click', function () {
          const section = header.closest('.mob-gen-section');
          const wasOpen = section.classList.contains('open');
          content.querySelectorAll('.mob-gen-section').forEach(function (s) {
            s.classList.remove('open');
            s.querySelector('.mob-gen-header').setAttribute('aria-expanded', 'false');
          });
          if (!wasOpen) {
            section.classList.add('open');
            header.setAttribute('aria-expanded', 'true');
          }
        });
      });

      // Sub-header toggle — only Gen 3/4 (button elements); Gen 2 uses a static div
      content.querySelectorAll('button.mob-parent-header').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
          e.stopPropagation();
          const group = btn.closest('.mob-parent-group');
          const isOpen = group.classList.toggle('open');
          btn.setAttribute('aria-expanded', isOpen);
        });
      });

      // Card tap → open modal
      content.querySelectorAll('.mob-card').forEach(function (card) {
        const id = card.dataset.id;
        card.addEventListener('click', function () { openModal(id); });
        card.addEventListener('keydown', function (e) {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openModal(id); }
        });
      });
    }

    renderMobAll();

    // Drag-to-scroll on the tree wrapper
    const wrap = document.getElementById('treeWrap');
    let isDragging = false, startX = 0, scrollLeft = 0;
    wrap.addEventListener('mousedown', function (e) {
      isDragging = true;
      startX = e.pageX - wrap.offsetLeft;
      scrollLeft = wrap.scrollLeft;
      wrap.style.cursor = 'grabbing';
    });
    wrap.addEventListener('mouseleave', function () { isDragging = false; wrap.style.cursor = 'grab'; });
    wrap.addEventListener('mouseup',    function () { isDragging = false; wrap.style.cursor = 'grab'; });
    wrap.addEventListener('mousemove',  function (e) {
      if (!isDragging) return;
      e.preventDefault();
      wrap.scrollLeft = scrollLeft - (e.pageX - wrap.offsetLeft - startX) * 1.2;
    });
  });
</script>

<style is:global>
  /* ── KEYFRAME ANIMATIONS ── */
  @keyframes ft-fade-up {
    from { opacity: 0; transform: translateY(18px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)    scale(1); }
