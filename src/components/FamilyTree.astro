    -webkit-overflow-scrolling: touch;
  }

  /* ── Accordion section ── */
  .mob-gen-section {
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid rgba(201,146,42,0.22);
    box-shadow: 0 2px 12px rgba(0,0,0,0.06);
  }

  /* ── Clickable header row ── */
  .mob-gen-header {
    width: 100%;
    display: flex; align-items: center; gap: 12px;
    padding: 14px 16px;
