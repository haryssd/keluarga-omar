  }
  .legend-circle.patriarch-circle { background: var(--hijau); border-color: var(--emas2); }
  .legend-circle.deceased-circle  { filter: grayscale(0.6); border-style: dashed; border-color: var(--text3); }

  /* ── MOBILE VIEW — Collapsible Accordion ── */
  .ft-mobile { display: none; }

  @media (max-width: 768px) {
    /* Remove the 100vh min-height so body shrinks to content height */
